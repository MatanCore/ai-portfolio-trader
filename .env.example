# Anthropic API (NOT REQUIRED — local mode uses Claude Code auth via `claude login`)
# Leave these blank unless you later switch to direct API billing.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=

# Database
DATABASE_URL=sqlite:///./portfolio.db

# Admin
ADMIN_TOKEN=change-me-to-a-secret-token

# Scheduler (ET time, 24h format)
DAILY_RUN_HOUR=16
DAILY_RUN_MINUTE=30

# Email notifications (Gmail App Password recommended)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=you@gmail.com

# Telegram (one-way decision notifications)
TELEGRAM_ENABLED=false

# Telegram bot (two-way remote control: /status /positions /decision /run)
# NOTE: Telegram bot polling currently has a macOS threading issue in python-telegram-bot.
# As a workaround: use the HTTP dashboard at http://localhost:8000 or set up a VPS to run the bot.
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=      # from @BotFather (not functional on macOS yet)
TELEGRAM_CHAT_ID=        # your numeric chat ID
